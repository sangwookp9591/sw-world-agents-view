# swkit-office 환경변수
# cp .env.example .env.local 로 복사하여 사용하세요.

# ─── 서버 측 (Next.js 앱) ───────────────────────
# API 인증 시크릿 (미설정 시 인증 스킵)
# RELAY_SECRET=sk-office-your-random-secret

# ─── 클라이언트 측 (Claude Code hooks / CLI) ─────
# Office 서버 URL
#   hooks 기본값: http://localhost:3000
#   CLI 기본값:   https://office.sw-world.site
# SWKIT_OFFICE_URL=https://office.sw-world.site

# 팀 ID (기본: default)
# SWKIT_TEAM_ID=your-team

# 에이전트 표시 이름 (기본: $USER)
# SWKIT_AGENT_NAME=your-name

# 에이전트 역할 (기본: developer)
# SWKIT_AGENT_ROLE=developer

# ─── 디버깅 ─────────────────────────────────────
# Hook 에러 상세 출력 (1로 설정 시 stderr 로그)
# SWKIT_DEBUG=1
